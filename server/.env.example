# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use long, random strings — at least 64 characters each.
# NEVER reuse JWT_SECRET for refresh tokens — they must be completely separate keys.
JWT_SECRET=your_long_random_access_token_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_completely_separate_long_random_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ── Frontend URL (CORS + OAuth redirects) ─────────────────────────────────────
# Development:  http://localhost:5173
# Production:   https://your-app.vercel.app  (your actual Vercel deployment URL)
CLIENT_URL=http://localhost:5173

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
#   Homepage URL:     http://localhost:5173
#   Callback URL:     http://localhost:8000/api/auth/github/callback
# For production, add a second OAuth App with your Render/Vercel URLs.
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/github/callback
# Optional: separate secret for the OAuth state JWT. Falls back to JWT_SECRET if not set.
GITHUB_STATE_SECRET=your_optional_github_state_jwt_secret

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini API key — get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key
# NVIDIA NIM API key — optional, only needed if NVIDIA AI features are enabled
NVIDIA_API_KEY=your_nvidia_api_key_optional

# ── Brevo Transactional Email API ─────────────────────────────────────────────
# CodeLens uses Brevo to send OTP emails (signup verification + password reset).
# No SMTP setup required — just an API key.
#
# Setup (takes ~2 minutes):
#   1. Register free at https://www.brevo.com/pricing/ (300 emails/day, no credit card)
#   2. Log in → Settings → SMTP & API → API Keys tab → Generate a new API key
#   3. Copy the full key immediately (shown only once). Confirm status is "Active".
#   4. Go to Senders, Domains & IPs → Senders → Add a new sender
#   5. Add your Gmail address and verify it via the confirmation email Brevo sends
#   6. Paste the key and your verified email below
#
# Each contributor uses their own free Brevo account for local development.
# NEVER commit your BREVO_API_KEY to Git — server/.env is in .gitignore.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=yourname@gmail.com
BREVO_SENDER_NAME=CodeLens
